# Inner Cosmos — Environment Variables Template
# Copy to .env and fill in values

# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
DB_USER=innercosmos
DB_PASSWORD=change_me_db_password

# ── LLM API Keys ─────────────────────────────────────────────
LLM_API_KEY=your_llm_api_key_here
LLM_MODE=prod
LLM_PROVIDER=minimax

# ── Versioned memory embeddings (OpenAI-compatible /embeddings) ──
# Disabled unless a provider credential is explicitly supplied. When enabled,
# startup fails closed if the key is missing; raw memory text is never logged.
MEMORY_EMBEDDING_ENABLED=false
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_BASE_URL=https://api.openai.com/v1
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_VERSION=2026-01
MEMORY_EMBEDDING_DIMENSIONS=1536
MEMORY_EMBEDDING_REBUILD_BATCH_SIZE=50
MEMORY_EMBEDDING_REBUILD_DELAY_MS=60000

# ── CORS (comma-separated origins) ──────────────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Security ────────────────────────────────────────────────
DEMO_SEED_ENABLED=false

# ── Monitoring ──────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password

# ── SSL (Let's Encrypt) ─────────────────────────────────────
# Run: certbot --nginx -d yourdomain.com
