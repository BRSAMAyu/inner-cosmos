# Copy to .env.mobile only for an authorized environment. Never commit secrets here.
# Production mobile builds reject non-HTTPS, local/private, credential-bearing, path,
# query, fragment, custom-port, and non-allowlisted API URLs. The allowlist is compiled
# into the signed build and must contain the exact production origin.
VITE_API_BASE_URL=https://api.example.invalid
VITE_API_ALLOWED_ORIGINS=https://api.example.invalid
