{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Inner Cosmos",
  "version": "0.1.0",
  "identifier": "sg.innercosmos.desktop",
  "build": {
    "frontendDist": "../../src/main/resources/static/app/aurora",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm exec vite --mode tauri-local",
    "beforeBuildCommand": "pnpm build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Inner Cosmos",
        "width": 1280,
        "height": 860,
        "minWidth": 390,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://api.innercosmos.sg https://auth.innercosmos.sg; media-src 'self' blob:; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": { "desktop": { "schemes": ["innercosmos"] } }
  }
}
